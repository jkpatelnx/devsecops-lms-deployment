####################################################################
# MONITORING SECRETS (DO NOT COMMIT TO GITHUB)
####################################################################

# Grafana admin credentials
GRAFANA_ADMIN_PASSWORD="super_secret_admin_password"

# Grafana Email Alerting (SMTP via Gmail)
# 1. Use your Gmail address for USER and FROM_ADDRESS
# 2. Go to Google Account -> Security -> 2-Step Verification -> App Passwords to generate the password
GRAFANA_SMTP_ENABLED="true"
GRAFANA_SMTP_HOST="smtp.gmail.com:587"
GRAFANA_SMTP_USER="your-email@gmail.com"
GRAFANA_SMTP_PASSWORD="your-google-app-password" 
GRAFANA_SMTP_FROM_ADDRESS="your-email@gmail.com" 
GRAFANA_SMTP_FROM_NAME="Grafana"

# IP of the App EC2 instance for Prometheus scraping
# This will be automatically injected into prometheus/prometheus.yml
APP_EC2_IP="100.67.150.76"
