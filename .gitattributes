# GitHub Linguist overrides for DevSecOps repositories

# Count YAML
*.yml linguist-detectable=true
*.yaml linguist-detectable=true
.github/workflows/*.yml linguist-detectable=true
.github/workflows/*.yaml linguist-detectable=true

# Count Dockerfiles
Dockerfile linguist-detectable=true
**/Dockerfile linguist-detectable=true

# Count Shell
*.sh linguist-detectable=true

# Ignore docs from language stats
*.md linguist-documentation=true

# Ignore draw.io generated XML from stats
*.drawio linguist-generated=true
